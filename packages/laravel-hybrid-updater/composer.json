{
  "name": "hybrid/laravel-hybrid-updater",
  "description": "Laravel package for Android APK + Web OTA update metadata",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "HybridUpdater\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "HybridUpdater\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit -c phpunit.xml.dist",
    "analyse": "phpstan analyse -c phpstan.neon.dist"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "HybridUpdater\\HybridUpdaterServiceProvider"
      ]
    }
  },
  "require": {
    "php": "^8.2",
    "illuminate/support": "^11.0|^12.0|^13.0"
  }
}
